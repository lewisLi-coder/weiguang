ZHIPU_API_KEY=your_zhipu_api_key_here
# EdgeOne Pages production history storage should bind a KV namespace named WEIGUANG_KV.
# Local development still falls back to data/chat-history.json or optional Upstash Redis.
UPSTASH_REDIS_REST_URL=optional_local_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=optional_local_upstash_redis_rest_token
PORT=3000
